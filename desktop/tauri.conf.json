{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentic Engine",
  "version": "0.3.0",
  "identifier": "com.agentic.engine",
  "build": {
    "beforeDevCommand": "python -m uvicorn agentic_engine.server:app --host 127.0.0.1 --port 8765 --reload",
    "beforeBuildCommand": "python -m pip install -e .",
    "devUrl": "http://127.0.0.1:8765",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agentic Engine",
        "width": 1280,
        "height": 860,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "url": "http://127.0.0.1:8765/h5/page"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:8765 ws://127.0.0.1:8765; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "deb", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "shortDescription": "Local-first agentic engine on Bailian Qwen.",
    "longDescription": "Agentic Engine — multi-agent framework, MCP bridge, cron, sessions, RAG, OTel, JWT-RBAC, served from a single FastAPI process inside a native shell.",
    "category": "DeveloperTool"
  }
}
