# ===== Bailian (DashScope) OpenAI-compatible endpoints =====
# China region
DASHSCOPE_API_KEY_CN=sk-xxxxxx
DASHSCOPE_BASE_URL_CN=https://dashscope.aliyuncs.com/compatible-mode/v1

# Singapore region (international)
DASHSCOPE_API_KEY_SG=sk-xxxxxx
DASHSCOPE_BASE_URL_SG=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Active region: cn | sg
AGENTIC_REGION=sg

# Default models
AGENTIC_MODEL_DEFAULT=qwen-plus
AGENTIC_MODEL_FAST=qwen-turbo
AGENTIC_MODEL_STRONG=qwen3-max

# Storage
AGENTIC_HOME=~/.agentic-engine

# Optional IM channel keys (leave blank to disable)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
DINGTALK_WEBHOOK=
